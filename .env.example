# SENTINEL Environment Configuration
# Copy this to .env and fill in your values

# API
FLASK_ENV=development
FLASK_DEBUG=1
API_PORT=5000
API_HOST=0.0.0.0

# Frontend
VITE_API_BASE=http://localhost:5000

# Alerts (optional — leave empty to disable)
SLACK_WEBHOOK_URL=
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_FROM=sentinel@yourorg.com
EMAIL_TO=security-team@yourorg.com

# Auto-block critical users (set to 1 to enable — use with caution)
AUTO_BLOCK_CRITICAL=0
